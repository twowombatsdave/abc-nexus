# Copy to `.env` for local Streamlit (or use `scripts/init_local_env.ps1`).
# Never commit real values — `.env` is gitignored.

ASANA_ACCESS_TOKEN=PASTE_YOUR_PERSONAL_ACCESS_TOKEN_HERE
ASANA_WORKSPACE_GID=PASTE_YOUR_WORKSPACE_GID_HERE

# Optional — comma-separated (default Alan Doran, Cormac Folan):
# ASANA_ASSIGNEE_NAMES=Alan Doran,Cormac Folan

# Optional — project GID (default 1209401086303491):
# ASANA_PROJECT_GID=1209401086303491

# Optional — use workspace+assignee instead of project scope (if project returns no rows):
# ASANA_TASK_SCOPE=workspace

# Optional — project scope: also include incomplete tasks with no assignee (default: assigned only):
# ASANA_PROJECT_INCLUDE_UNASSIGNED=true

# Optional — project scope: walk subtasks (default off):
# ASANA_PROJECT_INCLUDE_SUBTASKS=true
# ASANA_PROJECT_SUBTASK_MAX_DEPTH=5
# ASANA_PROJECT_SUBTASK_MAX_CONCURRENCY=8
